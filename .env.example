# PostgreSQL Configuration (development defaults only)
# These values are intended for local development and must be changed for any real deployment.
DB_USER=user
DB_PASSWORD=password
DB_NAME=ums_db
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}"

# Security configuration for password protection
# Development-only defaults — must be changed in any real deployment
APP_PASSWORD=change-me-in-dev
AUTH_SECRET=change-me-too
